{
  "name": "@bounded-systems/schema-gen",
  "version": "0.1.0",
  "description": "Project zod schemas to explicit, fast-types-clean TypeScript (zod → JSON Schema → .d.ts)",
  "bounded": {
    "tagline": "Project zod schemas to explicit, fast-types-clean TypeScript (zod → JSON Schema → .d.ts)",
    "kind": "guest",
    "facet": "verb",
    "role": "generator",
    "domain": "schema/types"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/schema-gen.git"
  },
  "homepage": "https://github.com/bounded-systems/schema-gen#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/schema-gen/issues"
  },
  "keywords": [
    "zod",
    "json-schema",
    "codegen",
    "jsr",
    "fast-types",
    "typescript"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "json-schema-to-typescript": "^15.0.4"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bounded-systems/seam-check": "npm:@jsr/bounded-systems__seam-check@^0.1.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
